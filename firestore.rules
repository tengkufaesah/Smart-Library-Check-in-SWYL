rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidCheckin(data) {
      return data.keys().hasAll(['type', 'name', 'student_id', 'class_level', 'user_type', 'purpose', 'check_in_time', 'is_checked_out']) &&
             data.type == 'checkin' &&
             data.name is string && data.name.size() > 0 &&
             data.student_id is string && data.student_id.size() > 0 &&
             data.user_type in ['นักเรียน', 'ครู/บุคลากร'] &&
             data.is_checked_out is bool;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['schoolName', 'welcomeText', 'footerText']) &&
             data.schoolName is string &&
             data.welcomeText is string &&
             data.footerText is string;
    }

    // Checkins collection
    match /checkins/{checkinId} {
      allow read: if true;
      allow create, update: if isValidCheckin(request.resource.data);
      allow delete: if false; // Only admin should delete, but we don't have auth yet
    }

    // Settings collection
    match /settings/general {
      allow read: if true;
      allow write: if isValidSettings(request.resource.data);
    }
  }
}
